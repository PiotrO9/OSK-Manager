# Backend Express (bez końcowego /). BFF: /api/auth/* → proxy + httpOnly na hoście Nuxt.
# Domyślnie, jeśli puste: używane jest NUXT_PUBLIC_API_BASE (to samo co klient dla useApi).
NUXT_API_UPSTREAM=http://localhost:4000

# Opcjonalnie: zewnętrzne API (useApi). Może być takie samo jak NUXT_API_UPSTREAM.
NUXT_PUBLIC_API_BASE=http://localhost:4000
